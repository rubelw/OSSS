# Rename this file to `.env` for local development.

APP_NAME=My API

# App DB (async URL for the runtime app)
DATABASE_URL=postgresql+asyncpg://app:secret@db:5432/app

# Keycloak (service name inside the compose/podman network)
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=myrealm
KEYCLOAK_CLIENT_ID=myapi
KEYCLOAK_CLIENT_SECRET=admin
KEYCLOAK_EXPECT_AUD=true
KEYCLOAK_VERIFY_TLS=false
